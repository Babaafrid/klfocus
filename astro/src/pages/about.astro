---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = 'About - FOCUS';
---
<BaseLayout {title}>
  <section class="mx-auto max-w-7xl px-6 py-16">
    <h1 class="text-3xl md:text-4xl font-black mb-6">About FOCUS</h1>
    <p class="text-white/80 leading-relaxed max-w-3xl">FOCUS is a platform for university CSE students to address grievances and promote academic growth. It aims to empower students with skills necessary for the evolving global tech landscape, fostering teamwork and knowledge exchange.</p>
  </section>
</BaseLayout>
