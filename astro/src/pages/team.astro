---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = 'Team - FOCUS';
---
<BaseLayout {title}>
  <section class="mx-auto max-w-7xl px-6 py-16">
    <h1 class="text-3xl md:text-4xl font-black mb-8">Our Team</h1>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {[
        { name: 'Garikipati Rishitha', role: 'President', img: '/klfocus/assets/img/Newteam/secretary.jpg' },
        { name: 'V Sumadhar', role: 'Vice President', img: '/klfocus/assets/img/Newteam/provisiondir.jpg' },
        { name: 'To Be Announced', role: 'Treasurer', img: '' },
        { name: 'To Be Announced', role: 'Secretary', img: '' },
      ].map((m) => (
        <div class="rounded-2xl overflow-hidden bg-card border border-white/10">
          <div class="h-56 bg-white/5">
            {m.img ? <img src={m.img} alt={m.name} class="w-full h-full object-cover"/> : <div class="w-full h-full flex items-center justify-center text-white/40 text-5xl">👤</div>}
          </div>
          <div class="p-4">
            <div class="font-bold">{m.name}</div>
            <div class="text-accent text-sm">{m.role}</div>
          </div>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
